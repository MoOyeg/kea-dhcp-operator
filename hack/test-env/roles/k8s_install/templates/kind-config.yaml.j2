# KinD cluster configuration for {{ cluster_name }}
# Generated by ansible - do not edit manually
kind: Cluster
apiVersion: kind.x-k8s.io/v1alpha4
name: {{ cluster_name }}
networking:
  apiServerAddress: "{{ detected_vm_ip }}"
  podSubnet: "{{ pod_network_cidr }}"
  serviceSubnet: "{{ service_cidr }}"
nodes:
  - role: control-plane
{% if kind_cluster_config.extra_port_mappings | default([]) | length > 0 %}
    extraPortMappings:
{% for mapping in kind_cluster_config.extra_port_mappings %}
      - containerPort: {{ mapping.container_port }}
        hostPort: {{ mapping.host_port }}
        protocol: {{ mapping.protocol | default("TCP") }}
{% endfor %}
{% endif %}
{% if kind_cluster_config.extra_mounts | default([]) | length > 0 %}
    extraMounts:
{% for mount in kind_cluster_config.extra_mounts %}
      - hostPath: {{ mount.host_path }}
        containerPath: {{ mount.container_path }}
{% endfor %}
{% endif %}

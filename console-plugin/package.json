{
  "name": "kea-dhcp-console-plugin",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "webpack serve --mode development",
    "build": "NODE_OPTIONS=--max-old-space-size=4096 webpack --mode production",
    "start": "npm run dev",
    "lint": "eslint src/ --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "consolePlugin": {
    "name": "kea-dhcp-console-plugin",
    "version": "0.0.1",
    "displayName": "Kea DHCP",
    "description": "OpenShift Console plugin for managing Kea DHCP servers and viewing leases",
    "exposedModules": {
      "DHCPServerListPage": "./src/components/DHCPServerListPage/index.ts",
      "DHCPServerDetailPage": "./src/components/DHCPServerDetailPage/index.ts",
      "LeasesPage": "./src/components/LeasesPage/index.ts"
    },
    "dependencies": {
      "@console/pluginAPI": "*"
    }
  },
  "dependencies": {
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-router-dom": "^5.3.4"
  },
  "devDependencies": {
    "@openshift-console/dynamic-plugin-sdk": "^1.6.0",
    "@openshift-console/dynamic-plugin-sdk-webpack": "^1.3.0",
    "@patternfly/react-core": "^5.4.0",
    "@patternfly/react-icons": "^5.4.0",
    "@patternfly/react-table": "^5.4.0",
    "@types/react": "^17.0.91",
    "@types/react-dom": "^17.0.26",
    "@types/react-router-dom": "^5.3.3",
    "css-loader": "^6.10.0",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.4.5",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  }
}
